# Stripe — replace with your keys from https://dashboard.stripe.com/apikeys
# Secret key: never commit the real value — add it directly to Netlify env vars
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe webhook signing secret — get from Stripe dashboard > Webhooks
# For local testing: stripe listen --forward-to localhost:8888/.netlify/functions/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# CreativeHub / ThePrintSpace fulfilment
CREATIVEHUB_API_KEY=your_creativehub_api_key_here

# Vite client-side (prefix VITE_ to expose to the browser bundle)
# Not currently used — checkout uses server-side redirect flow
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
